# Copiar a .dev.vars (gitignored) para desarrollo local
BETTER_AUTH_SECRET=generar-con-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:5173
# Canal de prueba del agente: la web llama a la API (apps/api) server-to-server
