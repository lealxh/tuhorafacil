# Copiar a .dev.vars (gitignored) para desarrollo local
WA_VERIFY_TOKEN=demo-verify-token
# Sin ANTHROPIC_API_KEY el agente degrada con gracia (responde "te respondo en un momento")
ANTHROPIC_API_KEY=
# Sin WA_ACCESS_TOKEN los envíos a WhatsApp se loguean en vez de enviarse (modo dev)
WA_ACCESS_TOKEN=
# Secreto compartido con la web para el canal de prueba del agente (/mock/chat)
MOCK_CHAT_SECRET=dev-mock-secret
# Kapso (BSP de WhatsApp): API key del proyecto y secret del webhook (dashboard → Integrations → Webhooks)
KAPSO_API_KEY=
KAPSO_WEBHOOK_SECRET=
